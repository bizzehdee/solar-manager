[Unit]
Description=SolarVolt — vendor-agnostic solar/battery management
Documentation=https://github.com/bizzehdee/solar-manager/blob/main/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@USER@
Group=@GROUP@
WorkingDirectory=@WORKDIR@
EnvironmentFile=@ENVFILE@
ExecStart=@PYTHON@ -m uvicorn app.main:app --host 0.0.0.0 --port @PORT@
Restart=on-failure
RestartSec=5

# Light hardening — this is a single-house LAN service, but drop what we safely can.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=@DBDIR@ @WORKDIR@

[Install]
WantedBy=multi-user.target
