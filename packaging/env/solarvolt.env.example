# SolarVolt configuration — systemd EnvironmentFile (plan.md §13).
# One config surface for every deploy path. After editing, apply with:
#   sudo systemctl restart solarvolt
# install.sh copies this to /etc/solarvolt/solarvolt.env on first install and never
# overwrites it afterwards, so your settings survive upgrades.

# ── Control / safety ────────────────────────────────────────────────────────
# Master switch for write-back to the inverter (settings changes + automation
# apply). OFF = monitoring only. Turn on only once you trust the register map.
SOLARVOLT_ENABLE_CONTROL=false

# ── Storage ─────────────────────────────────────────────────────────────────
# SQLite lives outside the app dir so it survives a re-clone / rebuild.
SOLARVOLT_DB_PATH=/var/lib/solarvolt/solarvolt.db
SOLARVOLT_RETENTION_DAYS=14

# ── Polling / cadence (seconds) ─────────────────────────────────────────────
SOLARVOLT_POLL_INTERVAL_S=3.0
SOLARVOLT_PERSIST_INTERVAL_S=30.0
SOLARVOLT_AGGREGATE_INTERVAL_S=300.0
SOLARVOLT_ALERT_INTERVAL_S=30.0
SOLARVOLT_AUTOMATION_INTERVAL_S=300.0

# ── Devices ─────────────────────────────────────────────────────────────────
# Inverters/devices are configured in the web UI under Settings › Devices (connection type,
# serial port / host, profile, …) and stored in the database — there are no device env vars.
# A fresh install starts on the built-in dummy simulator; add your real device(s) in the UI.
# (install.sh still pins a USB-RS485 adapter to a stable /dev/solarvolt-rs485 path for you to
# pick from the serial-port dropdown.)
